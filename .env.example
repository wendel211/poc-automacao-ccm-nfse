# Resolvedor de captcha (2Captcha) — necessário para baixar a NFS-e Nacional
# (hCaptcha da consulta pública), o reCAPTCHA do SIAT/POA e captchas de imagem.
# Obtenha a chave em https://2captcha.com/ e EXPORTE como variável de ambiente
# antes de rodar o pipeline (não é lida de arquivo):
#   PowerShell:  $env:TWOCAPTCHA_API_KEY = "sua_chave_real"
#   bash:        export TWOCAPTCHA_API_KEY="sua_chave_real"
# NUNCA versione a chave real. Este arquivo é só o modelo (apenas o nome da variável).
TWOCAPTCHA_API_KEY=sua_chave_aqui
